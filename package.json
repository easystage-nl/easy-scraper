{
  "name": "easy-stage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite",
    "build:web": "vite build",
    "deploy": "vite build && wrangler deploy",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute stagemarkt --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute stagemarkt --local --file=./schema.sql",
    "db:query": "wrangler d1 execute stagemarkt --remote --command",
    "db:query:local": "wrangler d1 execute stagemarkt --local --command",
    "trigger:local": "curl -s 'http://localhost:8787/__scheduled?cron=*/10+*+*+*+*'"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^3.80.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0"
  }
}
